# Copy this to `.env` (gitignored) and fill in your key. ReqLLM auto-loads `.env` from this
# directory at startup, so there's no need to `export` anything — just `mix phx.server`.
ANTHROPIC_API_KEY=sk-ant-...

# Optional — override the Postgres connection (defaults to 127.0.0.1:5433):
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/agentix_demo_dev
